PORT=8080
APP_ENV=development

# PostgreSQL
DATABASE_URL=postgres://postgres:password@localhost:5432/famcal?sslmode=disable

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRY_HOURS=720

# Replicate (Flux)
REPLICATE_API_KEY=r8_your_key_here
REPLICATE_FLUX_MODEL=black-forest-labs/flux-1.1-pro
REPLICATE_WEBHOOK_URL=https://your-domain.com/api/v1/webhooks/imagegen/replicate%2Fflux
# whsec_... value from Replicate; used for HMAC verification of webhook callbacks
REPLICATE_WEBHOOK_SECRET=

# S3-compatible storage (use MinIO locally)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=famcal-images
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# Identity providers — required (server refuses to start if unset)
# Apple: your app's Bundle ID; used as the audience claim on Apple ID tokens
APPLE_BUNDLE_ID=com.yourorg.famcalinsta
# Google: iOS OAuth 2.0 client ID from Google Cloud Console
GOOGLE_IOS_CLIENT_ID=REPLACE.apps.googleusercontent.com

# Token costs (how many tokens each action costs)
TOKEN_COST_FULL_GENERATION=12
TOKEN_COST_SINGLE_REGEN=1
TOKEN_COST_PDF_EXPORT=5

# OpenAI — only used by the disposable Test Lab medium
OPENAI_API_KEY=
